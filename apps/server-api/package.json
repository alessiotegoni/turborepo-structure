{
    "name": "@beeto/server-api",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc",
        "clean": "git clean -xdf .cache .turbo dist node_modules",
        "dev": "pnpm with-env tsx watch src/main.ts",
        "start": "pnpm with-env node dist/main.js",
        "typecheck": "tsc --noEmit",
        "with-env": "dotenv -e ../../.env --"
    },
    "dependencies": {
        "@beeto/api": "workspace:*",
        "@beeto/payments": "workspace:*",
        "@trpc/server": "catalog:",
        "cors": "^2.8.5",
        "express": "^4.21.2",
        "superjson": "2.2.3"
    },
    "devDependencies": {
        "@beeto/eslint-config": "workspace:*",
        "@beeto/prettier-config": "workspace:*",
        "@beeto/tsconfig": "workspace:*",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "catalog:",
        "eslint": "catalog:",
        "prettier": "catalog:",
        "tsx": "^4.19.2",
        "typescript": "catalog:"
    },
    "prettier": "@beeto/prettier-config"
}
