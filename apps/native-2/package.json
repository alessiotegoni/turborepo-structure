{
  "name": "@beeto/native-2",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules",
    "with-env": "dotenv -e ../../.env --",
    "dev": "pnpm with-env expo start",
    "dev:android": "pnpm with-env expo start --android",
    "dev:ios": "pnpm with-env expo start --ios",
    "android": "pnpm with-env expo run:android",
    "ios": "pnpm with-env expo run:ios",
    "generate:android": "pnpm with-env expo prebuild --platform android --clean",
    "generate:ios": "pnpm with-env expo prebuild --platform ios --clean",
    "generate": "pnpm with-env expo prebuild --clean",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@beeto/auth": "workspace:^",
    "@beeto/features": "workspace:^",
    "@beeto/ui": "workspace:*",
    "@gorhom/bottom-sheet": "^5.2.8",
    "react-native-mmkv": "catalog:",
    "@react-navigation/bottom-tabs": "^7.7.3",
    "@react-navigation/elements": "^2.8.1",
    "@react-navigation/native": "^7.1.28",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "expo": "~55.0.5",
    "expo-constants": "~55.0.7",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.7",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "catalog:react19",
    "react-native": "catalog:",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@beeto/api": "workspace:*",
    "@beeto/eslint-config": "workspace:*",
    "@beeto/prettier-config": "workspace:*",
    "@beeto/supabase": "workspace:*",
    "@beeto/tailwind-config": "workspace:*",
    "@beeto/tsconfig": "workspace:*",
    "@types/react": "catalog:react19",
    "cross-env": "^7.0.3",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "uniwind": "latest"
  },
  "private": true
}
