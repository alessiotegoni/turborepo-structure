{
  "name": "@beeto/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./helpers": {
      "types": "./dist/helpers.d.ts",
      "default": "./src/helpers.ts"
    },
    "./web/react": {
      "types": "./dist/web/react.d.ts",
      "default": "./src/web/react.tsx"
    },
    "./web/server": {
      "types": "./dist/web/server.d.ts",
      "default": "./src/web/server.tsx"
    },
    "./native": {
      "types": "./dist/native/index.d.ts",
      "default": "./src/native/index.tsx"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@beeto/email": "workspace:*",
    "@beeto/payments": "workspace:*",
    "expo-constants": "catalog:",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@beeto/db": "workspace:*",
    "@beeto/supabase": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/react-query": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "next": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19"
  },
  "peerDependenciesMeta": {
    "@beeto/db": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@beeto/db": "workspace:*",
    "@beeto/eslint-config": "workspace:*",
    "@beeto/prettier-config": "workspace:*",
    "@beeto/supabase": "workspace:*",
    "@beeto/tsconfig": "workspace:*",
    "@expo/metro-runtime": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/react-query": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "@types/react": "catalog:react19",
    "eslint": "catalog:",
    "next": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "typescript": "catalog:"
  },
  "prettier": "@beeto/prettier-config"
}
