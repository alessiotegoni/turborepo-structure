{
  "name": "@beeto/supabase",
  "private": true,
  "type": "module",
  "exports": {
    "./web": {
      "types": "./src/web.ts",
      "default": "./src/web.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./native": {
      "types": "./src/native.ts",
      "default": "./src/native.ts"
    },
    "./env": {
      "types": "./env.ts",
      "default": "./env.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/ssr": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "@t3-oss/env-core": "catalog:",
    "expo-secure-store": "~55.0.8",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@beeto/eslint-config": "workspace:*",
    "@beeto/prettier-config": "workspace:*",
    "@beeto/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@beeto/prettier-config"
}
