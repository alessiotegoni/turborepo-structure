{
  "name": "@beeto/supabase",
  "private": true,
  "type": "module",
  "exports": {
    "./admin": {
      "types": "./src/admin.ts",
      "default": "./src/admin.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./native": {
      "types": "./src/native.ts",
      "default": "./src/native.ts"
    },
    "./env.web": {
      "types": "./env.web.ts",
      "default": "./env.web.ts"
    },
    "./env.native": {
      "types": "./env.native.ts",
      "default": "./env.native.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "clean": "rimraf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "catalog:",
    "zod": "catalog:",
    "aes-js": "latest",
    "react-native-get-random-values": "latest"
  },
  "peerDependencies": {
    "@supabase/ssr": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "react-native-mmkv": "catalog:",
    "expo-secure-store": "catalog:"
  },
  "devDependencies": {
    "@supabase/ssr": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "react-native-mmkv": "catalog:",
    "expo-secure-store": "catalog:",
    "react-native-get-random-values": "latest",
    "@beeto/eslint-config": "workspace:*",
    "@beeto/prettier-config": "workspace:*",
    "@beeto/tsconfig": "workspace:*",
    "@expo/metro-runtime": "catalog:",
    "@types/node": "catalog:",
    "@types/aes-js": "latest",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@beeto/prettier-config"
}
