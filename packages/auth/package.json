{
  "name": "@beeto/auth",
  "private": true,
  "type": "module",
  "exports": {
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./web/hooks": {
      "types": "./src/web/hooks/index.ts",
      "default": "./src/web/hooks/index.ts"
    },
    "./web/providers": {
      "types": "./src/web/providers/index.ts",
      "default": "./src/web/providers/index.ts"
    },
    "./native/hooks": {
      "types": "./src/native/hooks/index.ts",
      "default": "./src/native/hooks/index.ts"
    },
    "./native/providers": {
      "types": "./src/native/providers/index.ts",
      "default": "./src/native/providers/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./env": {
      "types": "./env.ts",
      "default": "./env.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "generate": "dotenv -e ../../.env -- pnpx @better-auth/cli generate --config script/auth-cli.ts --output ../db/src/auth-schema.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@beeto/db": "workspace:*",
    "@beeto/supabase": "workspace:*",
    "@beeto/ui": "workspace:*",
    "@supabase/ssr": "catalog:",
    "@supabase/supabase-js": "catalog:",
    "@t3-oss/env-core": "catalog:",
    "@tanstack/react-query": "catalog:",
    "react": "catalog:react19",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@beeto/api": "workspace:*"
  },
  "devDependencies": {
    "@beeto/eslint-config": "workspace:*",
    "@beeto/prettier-config": "workspace:*",
    "@beeto/tsconfig": "workspace:*",
    "@types/react": "catalog:react19",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "react-native": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@beeto/prettier-config"
}
