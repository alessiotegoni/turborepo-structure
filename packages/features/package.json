{
  "name": "@beeto/features",
  "private": true,
  "type": "module",
  "exports": {
    "./events": {
      "types": "./src/events/index.ts",
      "default": "./src/events/index.ts"
    },
    "./events/web": {
      "types": "./src/events/web.ts",
      "default": "./src/events/web.ts"
    },
    "./events/native": {
      "types": "./src/events/native.ts",
      "default": "./src/events/native.ts"
    },
    "./posts": {
      "types": "./src/posts/index.ts",
      "default": "./src/posts/index.ts"
    },
    "./users": {
      "types": "./src/users/index.ts",
      "default": "./src/users/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@beeto/auth": "workspace:*",
    "@beeto/db": "workspace:*",
    "@beeto/ui": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "drizzle-zod": "catalog:",
    "react": "catalog:react19",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@beeto/api": "workspace:*"
  },
  "devDependencies": {
    "@beeto/eslint-config": "workspace:*",
    "@beeto/prettier-config": "workspace:*",
    "@beeto/tsconfig": "workspace:*",
    "@types/react": "catalog:react19",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "react-native": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@beeto/prettier-config"
