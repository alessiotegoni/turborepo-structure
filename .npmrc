# Abilita il hoist dei pacchetti nativi per ridurre la profondità dei path node_modules.
# Senza questo, pnpm installa i pacchetti in:
#   node_modules/.pnpm/react-native-worklets@0.7.2_hash/node_modules/react-native-worklets/
# Con questo, vengono hoistati in:
#   node_modules/react-native-worklets/
# Questo riduce la lunghezza dei path CMake su Windows, risolvendo:
#   "manifest 'build.ninja' still dirty after 100 tries"
#   (CMAKE_OBJECT_PATH_MAX=250 superato)
public-hoist-pattern[]=react-native-*
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=expo*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=*@heroui/*
